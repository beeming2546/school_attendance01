<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/style.css" />
  <title>สแกน QR เพื่อเช็กชื่อ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
</head>
<body>
   <% if (showNavbar) { %>
    <%- include('partials/navbar', { currentUser: currentUser, currentRole: currentRole }) %>
  <% } %>
  <h3 class="text-center">กรุณาสแกน QR Code</h3>
  <div id="reader" style="width: 300px; margin: auto;"></div>
  <div id="result" style="text-align: center; margin-top: 10px;"></div>

  <script>
  function onScanSuccess(decodedText) {
    const text = (decodedText || '').trim();

    // ถ้า QR เป็นลิงก์ /attendance/confirm/:token อยู่แล้ว → พาไปเลย
    const isConfirmUrl = /^https?:\/\/.+\/attendance\/confirm\/[A-Za-z0-9-]{10,}$/i.test(text);
    if (isConfirmUrl) {
      try { html5QrcodeScanner.clear(); } catch(e) {}
      window.location.href = text;
      return;
    }

    // กรณีเป็น token เปล่า → เรียก /api/scan เพื่อให้เซิร์ฟเวอร์ส่ง URL confirm กลับมา
    fetch('/api/scan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: text })
    })
    .then(async (res) => {
      const data = await res.json();
      if (res.ok && data.redirect) {
        window.location.href = data.redirect; // ✅ เด้งไปหน้า confirm
      } else {
        document.getElementById('result').innerText = data.error || 'สแกนไม่สำเร็จ';
        // เปิดสแกนต่อได้ถ้าต้องการ:
        // html5QrcodeScanner.render(onScanSuccess);
      }
    })
    .catch(err => {
      console.error(err);
      document.getElementById('result').innerText = 'เกิดข้อผิดพลาดในการเช็กชื่อ';
    });

    // หยุดสแกนหลังจากเจอ (กันยิงซ้ำ)
    try { html5QrcodeScanner.clear(); } catch(e) {}
  }

  const html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: 250 });
  html5QrcodeScanner.render(onScanSuccess);
</script>
  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
